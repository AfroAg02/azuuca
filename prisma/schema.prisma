datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String
  role       String   @default("USER")
  hourlyRate Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  attendances   Attendance[]
  absences      Absence[]
  leaveRequests  LeaveRequest[] @relation("UserLeaveRequests")
  createdLeaves  LeaveRequest[] @relation("CreatorLeaveRequests")
}

model Attendance {
  id       String  @id @default(cuid())
  userId   String
  date     String  // YYYY-MM-DD
  clockIn  String? // HH:mm:ss
  clockOut String? // HH:mm:ss

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Absence {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD
  reason String
  type   String // ILLNESS, EVENT, PLANNED, OTHER

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  userId     String?  // null for HOLIDAY (applies to everyone)
  createdBy  String   // who registered it
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  type       String   // VACATION, MEDICAL, PAID_LEAVE, UNJUSTIFIED, HOLIDAY
  reason     String
  hours      Float?   // only for HOLIDAY — paid hours for that day
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User? @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  creator User  @relation("CreatorLeaveRequests", fields: [createdBy], references: [id])
}
